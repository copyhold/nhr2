---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---
<div class="mb-12 border-b-2 border-black pb-4">
  <h3 class="text-4xl md:text-5xl lg:text-6xl">{title}</h3>
  {subtitle && <p class="mt-2 text-zinc-500 font-medium uppercase text-sm tracking-widest">{subtitle}</p>}
</div>
