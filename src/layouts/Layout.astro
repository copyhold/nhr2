---
interface Props {
	title: string;
}

const { title } = Astro.props;
import '../index.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="NHR - Negative Host Reviews. The platform that holds hosts accountable." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-surface text-brand-black font-sans antialiased min-h-screen">
		<slot />
	</body>
</html>
