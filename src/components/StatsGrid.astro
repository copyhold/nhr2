---
import { Shield, TriangleAlert } from 'lucide-react';
import Badge from './Badge.astro';
---
<section class="py-20 grid grid-cols-1 md:grid-cols-4 gap-8">
  <div class="md:col-span-2 bg-white border-2 border-black p-8 flex flex-col justify-between hover:shadow-brutalist transition-all cursor-default">
    <div>
      <Badge>Live Feed</Badge>
      <h2 class="text-3xl mt-6">Latest Host Alerts</h2>
    </div>
    <div class="mt-12 space-y-6">
      <div class="flex items-center gap-4 border-b border-zinc-100 pb-4">
        <TriangleAlert className="text-brand-orange h-6 w-6" />
        <p class="font-headline font-bold uppercase text-lg">Incident #9921: San Francisco, CA</p>
      </div>
      <div class="flex items-center gap-4 border-b border-zinc-100 pb-4">
        <TriangleAlert className="text-brand-orange h-6 w-6" />
        <p class="font-headline font-bold uppercase text-lg">Incident #9918: London, UK</p>
      </div>
    </div>
  </div>
  
  <div class="bg-brand-orange border-2 border-black p-8 flex flex-col items-center justify-center text-center shadow-brutalist transition-transform hover:-translate-y-1">
    <span class="text-7xl font-headline font-black text-white leading-none">98%</span>
    <p class="font-headline font-bold text-white uppercase text-sm mt-4 tracking-tighter">Accuracy Rate on Claims</p>
  </div>
  
  <div class="bg-white border-2 border-black p-8 flex flex-col justify-between hover:shadow-brutalist transition-all">
    <Shield className="text-brand-black h-12 w-12" />
    <p class="font-headline font-black text-brand-black uppercase text-2xl leading-none mt-8">100% Anonymous Reporting</p>
  </div>
</section>
